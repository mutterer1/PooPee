{
  "expo": {
    "name": "PooPee Health",
    "slug": "poopee-health",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/branding/icon.png",
    "scheme": "poopeehealth",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/branding/icon.png",
        "backgroundColor": "#F7F4EF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/branding/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F4EF",
          "image": "./assets/images/branding/splash-logo.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
